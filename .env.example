# Copy to .env and source it, or export these in your shell / CI.
# These override config-file values and are overridden by explicit CLI flags.

KVM_PILOT_HOST=192.168.8.1
KVM_PILOT_USER=admin
KVM_PILOT_PASSWD=changeme
# KVM_PILOT_PORT=443
# KVM_PILOT_SCHEME=https
# KVM_PILOT_TIMEOUT=30
# KVM_PILOT_VERIFY_SSL=false
# KVM_PILOT_TOTP_SECRET=BASE32SECRET

# Vision backend (Anthropic path)
ANTHROPIC_API_KEY=sk-ant-...
# Pin a vision model, or leave unset to auto-resolve the newest:
# KVM_PILOT_VISION_MODEL=

# Vision backend (local OpenAI-compatible path) — no API key needed for most:
# OPENAI_API_KEY=not-needed
