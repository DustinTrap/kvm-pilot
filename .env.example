# Copy to .env and source it, or export these in your shell / CI.
# These override config-file values and are overridden by explicit CLI flags.
# Full reference: docs/configuration.md

KVM_PILOT_HOST=192.168.8.1
KVM_PILOT_USER=admin
KVM_PILOT_PASSWD=changeme
# KVM_PILOT_PORT=443
# KVM_PILOT_SCHEME=https
# KVM_PILOT_TIMEOUT=30
# KVM_PILOT_DRIVER=glkvm          # pikvm (default) | glkvm | blikvm | fake | redfish
# KVM_PILOT_VERIFY_SSL=false
# KVM_PILOT_TOTP_SECRET=BASE32SECRET
# KVM_PILOT_REDFISH_AUTH=session  # redfish driver only: session | basic (no SessionService)
# KVM_PILOT_SSL_CA_FILE=~/pki/kvm-device.pem  # pin TLS to the device cert (overrides verify_ssl)
# KVM_PILOT_CONFIG=/path/to/config.toml   # config-file path override (default ~/.config/kvm-pilot/config.toml)

# Vision backend (Anthropic path)
ANTHROPIC_API_KEY=sk-ant-...
# Pin a vision model, or leave unset to auto-resolve the newest:
# KVM_PILOT_VISION_MODEL=

# Vision backend (local OpenAI-compatible path) — no API key needed for most:
# OPENAI_API_KEY=not-needed

# Vision backend selection (MCP server; the CLI uses --backend/--vision-url flags)
# KVM_PILOT_VISION_BACKEND=anthropic  # anthropic (default) | local (OpenAI-compatible)
# KVM_PILOT_VISION_URL=http://localhost:1234/v1  # local backend endpoint

# SSH channel to the MANAGED HOST's OS (not the KVM appliance) — see docs/configuration.md
# KVM_PILOT_SSH_HOST=10.0.1.50
# KVM_PILOT_SSH_USER=root
# KVM_PILOT_SSH_PORT=22
# KVM_PILOT_SSH_KEY=~/.ssh/id_ed25519

# MCP server only (src/kvm_pilot/mcp/server.py; the CLI/library ignore these)
# KVM_PILOT_PROFILE=homelab       # default config-file profile (CLI, library, and MCP server)
# KVM_PILOT_MCP_ALLOW_POWER=false # gate the destructive power tool (+ reboot chords)
# KVM_PILOT_MCP_ALLOW_HID=false   # gate type_text / press_key / send_shortcut / mouse
# KVM_PILOT_MCP_ALLOW_MEDIA=false # gate mount_iso / eject
# KVM_PILOT_MCP_ALLOW_SSH=false   # gate ssh_exec
# KVM_PILOT_MCP_PROFILES=homelab,homelab2  # fail-closed profile allowlist (unset = none; empty = allow nothing)
# KVM_PILOT_MCP_ELICIT=off        # per-invocation human elicitation is ON by default; 'off' disables
# KVM_PILOT_MCP_DRY_RUN=true      # force dry-run: log destructive MCP calls, don't send

# CLI + MCP server
# KVM_PILOT_SKIP_HEALTHCHECK=0    # skip the preflight healthcheck gate (not recommended)
