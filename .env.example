# Copy to .env and source it, or export these in your shell / CI.
# These override config-file values and are overridden by explicit CLI flags.
# Full reference: docs/configuration.md

KVM_PILOT_HOST=192.168.8.1
KVM_PILOT_USER=admin
KVM_PILOT_PASSWD=changeme
# KVM_PILOT_PORT=443
# KVM_PILOT_SCHEME=https
# KVM_PILOT_TIMEOUT=30
# KVM_PILOT_DRIVER=glkvm          # pikvm (default) | glkvm | blikvm | fake | redfish
# KVM_PILOT_VERIFY_SSL=false
# KVM_PILOT_TOTP_SECRET=BASE32SECRET
# KVM_PILOT_REDFISH_AUTH=session  # redfish driver only: session | basic (no SessionService)
# KVM_PILOT_CONFIG=/path/to/config.toml   # config-file path override (default ~/.config/kvm-pilot/config.toml)

# Vision backend (Anthropic path)
ANTHROPIC_API_KEY=sk-ant-...
# Pin a vision model, or leave unset to auto-resolve the newest:
# KVM_PILOT_VISION_MODEL=

# Vision backend (local OpenAI-compatible path) — no API key needed for most:
# OPENAI_API_KEY=not-needed

# MCP server only (mcp_server/server.py; the CLI/library ignore these)
# KVM_PILOT_PROFILE=homelab       # default config-file profile (CLI, library, and MCP server)
# KVM_PILOT_MCP_ALLOW_POWER=false # gate the destructive MCP power tool
# KVM_PILOT_MCP_DRY_RUN=true      # force dry-run: log destructive MCP calls, don't send
